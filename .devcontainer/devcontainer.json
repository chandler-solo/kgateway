{
  "name": "kgateway build-tools",
  "build": {
    "dockerfile": "../tools/build-tools/Dockerfile",
    "context": ".."
  },
  "remoteEnv": {
    "USE_GKE_GCLOUD_AUTH_PLUGIN": "True",
    "BUILD_WITH_CONTAINER": "0",
    "CARGO_HOME": "/home/.cargo",
    "RUSTUP_HOME": "/home/.rustup"
  },
  "postStartCommand": "if command -v docker >/dev/null 2>&1 && [ -e /var/run/docker.sock ]; then v=$(docker version --format '{{.Server.APIVersion}}' 2>/dev/null || true) && [ -n \"$v\" ] && echo \"export DOCKER_API_VERSION=$v\" | sudo tee /etc/profile.d/docker-api-version.sh >/dev/null; fi || true",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
    "ghcr.io/mpriscella/features/kind:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "rust-lang.rust-analyzer",
        "eamodio.gitlens",
        "zxh404.vscode-proto3",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml",
        "IBM.output-colorizer"
      ],
      "settings": {
        "files.eol": "\n",
        "go.useLanguageServer": true,
        "go.lintTool": "golangci-lint"
      }
    }
  }
}